BOT_TOKEN=your_telegram_bot_token_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=ege_helper
POSTGRES_USER=ege_user
POSTGRES_PASSWORD=ege_password
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- parser-сервис ---
# Запускать первый прогон сразу при старте контейнера
PARSER_RUN_ON_STARTUP=true
# Период между прогонами (часов)
PARSER_INTERVAL_HOURS=24
# Сколько одновременных запросов к sdamgia держим
PARSER_CONCURRENCY=4
# Пауза перед каждым запросом, секунды (вежливость к сдамгиа)
PARSER_REQUEST_DELAY=0.15
# URL до seed-дампа на GitHub Releases. При первом старте если БД пустая —
# parser скачает этот файл и развернёт через psql, чтобы не парсить часами.
# Оставь пустым если хочешь честно парсить с нуля.
PARSER_SEED_URL=https://github.com/WhymeUMR/EGE-helper/releases/latest/download/problems.sql.gz
